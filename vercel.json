{
  "cleanUrls": true,
  "redirects": [
    { "source": "/pages/home(.*)", "destination": "/", "permanent": true },
    { "source": "/pages/:path*", "destination": "/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/api/web/uploadImage", "destination": "/api/uploadImage" },
    { "source": "/api/web/sendMsg", "destination": "/api/sendMsg" },
    { "source": "/api/web/getWall", "destination": "/api/getWall" },
    { "source": "/", "destination": "/api/home" },
    { "source": "/home", "destination": "/api/home" },
    { "source": "/home/", "destination": "/api/home" },
    { "source": "/:path(home|hostel-details|locations|scam-reports|report-issue|login|signup|legal|services|demo|olpot).js", "destination": "/pages/:path/:path.js" },
    { "source": "/:dir(home|hostel-details|locations|scam-reports|report-issue|login|signup|legal|services|demo|olpot)/:file.js", "destination": "/pages/:dir/:file.js" },
    { "source": "/login", "destination": "/pages/login" },
    { "source": "/login/", "destination": "/pages/login" },
    { "source": "/signup", "destination": "/pages/signup" },
    { "source": "/signup/", "destination": "/pages/signup" },
    { "source": "/hostel-details", "destination": "/api/hostel-details" },
    { "source": "/hostel-details/", "destination": "/api/hostel-details" },
    { "source": "/locations", "destination": "/pages/locations" },
    { "source": "/locations/", "destination": "/pages/locations" },
    { "source": "/scam-reports", "destination": "/api/scam-reports" },
    { "source": "/scam-reports/", "destination": "/api/scam-reports" },
    { "source": "/report-issue", "destination": "/pages/report-issue" },
    { "source": "/report-issue/", "destination": "/pages/report-issue" },
    { "source": "/legal", "destination": "/pages/legal" },
    { "source": "/legal/", "destination": "/pages/legal" },
    { "source": "/services", "destination": "/api/services" },
    { "source": "/services/", "destination": "/api/services" },
    { "source": "/demo", "destination": "/pages/demo" },
    { "source": "/demo/", "destination": "/pages/demo" },
    { "source": "/olpot", "destination": "/pages/olpot" },
    { "source": "/olpot/", "destination": "/pages/olpot" },
    { "source": "/api/admin-auth", "destination": "/api/admin-auth" },
    { "source": "/api/cache-refresh", "destination": "/api/cache-refresh" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self' https://hostel.dekut.site;" }
      ]
    },
    {
      "source": "/(olpot|pages/olpot)(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/(.*)\\.(html|js|json)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    }
  ]
}
